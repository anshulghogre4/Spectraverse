# ── Azure (optional for Sprint 1 — required for Sprint 3+) ───────────────
AZURE_BLOB_ACCOUNT=spectraverse
AZURE_BLOB_KEY=your_storage_account_key_here
AZURE_VISION_API_KEY=your_vision_api_key_here
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend ───────────────────────────────────────────────────────────────
# Override path to semantic_mappings.json (set automatically in Docker)
# SEMANTIC_MAPPINGS_PATH=/app/semantic_mappings.json

# ── Frontend ──────────────────────────────────────────────────────────────
# Local dev: use localhost. Docker: use service name (http://backend:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Sprint 3: Azure OpenAI (GPT-4o vision + GPT-4o-mini mapping) ─────────
# Get these from Microsoft Foundry portal → your project → Models + endpoints
# All four can be left blank — backend falls back to mock responses
AZURE_OPENAI_ENDPOINT=https://your-foundry-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_aoai_key_here
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o
AZURE_OPENAI_GPT4O_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Sprint 3: Foundry IQ knowledge base (Azure AI Search) ────────────────
# Provision: Azure portal → Create resource → "Azure AI Search" → free tier
# Then in Foundry portal → Knowledge tab → connect search service → create KB
AZURE_SEARCH_ENDPOINT=https://your-search-svc.search.windows.net
AZURE_SEARCH_API_KEY=your_search_admin_key_here
FOUNDRY_KB_NAME=spectraverse-music-theory-kb
FOUNDRY_KS_NAME=music-theory-ks

