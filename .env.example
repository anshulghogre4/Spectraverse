# ── Azure (optional for Sprint 1 — required for Sprint 3+) ───────────────
AZURE_BLOB_ACCOUNT=spectraverse
AZURE_BLOB_KEY=your_storage_account_key_here
AZURE_VISION_API_KEY=your_vision_api_key_here
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend ───────────────────────────────────────────────────────────────
# Override path to semantic_mappings.json (set automatically in Docker)
# SEMANTIC_MAPPINGS_PATH=/app/semantic_mappings.json

# ── Frontend ──────────────────────────────────────────────────────────────
# Local dev: use localhost. Docker: use service name (http://backend:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
